<script>
    (function(){
        const body = document.body;
        const urlParams = new URLSearchParams(window.location.search);
        let lang = urlParams.get('lang') || localStorage.getItem('cvLang') || 'fr';
        if (lang !== 'fr' && lang !== 'en') lang = 'fr';
        body.setAttribute('data-cv-lang', lang);
        
        const switchBtn = document.getElementById('cvLangSwitch');
        const langSpan = switchBtn.querySelector('span');
        
        function updateUILang() {
            const current = body.getAttribute('data-cv-lang');
            langSpan.textContent = current === 'fr' ? 'English' : 'Français';
        }
        updateUILang();
        
        switchBtn.addEventListener('click', () => {
            const newLang = body.getAttribute('data-cv-lang') === 'fr' ? 'en' : 'fr';
            body.setAttribute('data-cv-lang', newLang);
            localStorage.setItem('cvLang', newLang);
            updateUILang();
            const url = new URL(window.location);
            url.searchParams.set('lang', newLang);
            window.history.replaceState({}, '', url);
        });
        
        // Téléchargement PDF via fetch robuste (force le download)
        document.getElementById('downloadPDFBtn').addEventListener('click', async function() {
            const currentLang = body.getAttribute('data-cv-lang');
            const pdfFileName = currentLang === 'fr' ? 'PDF_CV.pdf' : 'PDF_CV_EN.pdf';
            
            try {
                const response = await fetch(pdfFileName);
                if (!response.ok) throw new Error('PDF introuvable');
                const blob = await response.blob();
                const url = window.URL.createObjectURL(blob);
                const link = document.createElement('a');
                link.href = url;
                link.download = pdfFileName;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                setTimeout(() => window.URL.revokeObjectURL(url), 150);
            } catch (error) {
                console.warn('Fallback téléchargement:', error);
                const link = document.createElement('a');
                link.href = pdfFileName;
                link.download = pdfFileName;
                link.target = '_blank';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            }
        });

        // Bouton retour portfolio : redirection vers index.html (ou page principale)
        const backBtn = document.getElementById('backToPortfolio');
        if(backBtn) {
            backBtn.addEventListener('click', (e) => {
                e.preventDefault();
                window.location.href = 'index.html';
            });
        }
    })();
</script>
